---
import { Picture } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import { url } from '@utils/url';
import profileImage from '@assets/images/profile.jpg';
---

<BaseLayout
  title="À propos"
  description="Qui je suis, ce qui me motive, et comment j'envisage mon métier."
>
  <!-- Hero Section -->
  <section class="section-padding section-hero relative overflow-hidden">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-8 md:gap-12 lg:gap-16 items-center">
        <!-- Image -->
        <div class="order-2 lg:order-1" data-gsap="reveal">
          <div
            class="overflow-hidden shadow-hard-purple-xl border-3 border-primary-500 bg-dark-800 group transition-all duration-500"
          >
            <div class="aspect-[4/5] bg-dark-700 flex items-center justify-center">
              <Picture
                src={profileImage}
                formats={['avif', 'webp']}
                alt="Photo de Virgil CHAREYRE"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                width={400}
                height={500}
                priority
                quality={85}
              />
            </div>
          </div>
        </div>

        <!-- Text -->
        <div class="order-1 lg:order-2" data-gsap="hero">
          <p
            class="text-primary-400 font-heading font-semibold mb-6 uppercase tracking-wider text-sm"
          >
            À propos de moi
          </p>
          <h1 class="page-title">
            <span class="gradient-text-animated underline-zigzag" data-text="Virgil"
              >Virgil CHAREYRE</span
            >
          </h1>
          <p
            class="text-2xl sm:text-3xl md:text-4xl text-accent-400 mb-4 sm:mb-6 font-heading font-bold"
          >
            <span class="highlight-marker highlight-marker-accent">Développeur Web Fullstack</span>
          </p>
          <p class="text-gray-300 leading-relaxed mb-6 sm:mb-10 text-sm sm:text-base">
            Je crois qu'un bon produit se ressent dans les détails. Mon approche : peaufiner chaque
            interaction, soigner l'accessibilité, et livrer un travail dont je suis fier — pas juste
            fonctionnel, mais vraiment bien fait. Ce que je cherche : des collaborations
            authentiques sur des projets qui ont du sens, avec des personnes qui partagent mes
            valeurs.
          </p>

          <!-- Quick Info -->
          <div class="flex flex-wrap gap-3 sm:gap-6">
            <div
              class="flex items-center gap-2 px-3 sm:px-4 py-2 bg-dark-800 border-2 border-dark-600"
            >
              <svg
                class="w-5 h-5 text-primary-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <span class="text-gray-300 text-sm font-medium">France</span>
            </div>
            <div class="flex items-center gap-2 px-4 py-2 bg-dark-800 border-2 border-dark-600">
              <svg
                class="w-5 h-5 text-accent-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
              <span class="text-gray-300 text-sm font-medium">Disponible</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 1: Mes Valeurs -->
  <section
    class="section-padding section-alt section-lazy"
    id="valeurs"
    aria-labelledby="valeurs-heading"
  >
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <div class="content-section-header">
          <div class="icon-box">
            <svg
              class="w-6 h-6 text-primary-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
              ></path>
            </svg>
          </div>
          <h2 id="valeurs-heading" class="content-section-title">
            Mes <span class="text-primary-400 underline-memphis">Valeurs</span>
          </h2>
        </div>
        <div class="section-divider mb-10"></div>

        <p class="text-gray-400 mb-10 leading-relaxed">
          Ce qui me motive vraiment, c'est de fournir un <strong class="text-white"
            >travail hyper qualitatif et adapté</strong
          >. Tout peaufiner, créer une expérience aux petits oignons. La technologie au service d'un
          web plus éthique et accessible.
        </p>

        <dl class="grid md:grid-cols-2 gap-8 m-0" data-gsap="stagger">
          <div class="card-glow p-8">
            <dt class="text-xl font-heading font-bold text-white mb-3">Accessibilité</dt>
            <dd class="text-gray-300 text-sm leading-relaxed m-0">
              Le web doit être utilisable par tout le monde. L'inclusion n'est pas une option, c'est
              un minimum.
            </dd>
          </div>
          <div class="card-glow p-8">
            <dt class="text-xl font-heading font-bold text-white mb-3">Transparence</dt>
            <dd class="text-gray-300 text-sm leading-relaxed m-0">
              Code propre, communication claire, pas de bullshit. Je dis ce que je fais et je fais
              ce que je dis.
            </dd>
          </div>
          <div class="card-glow p-8">
            <dt class="text-xl font-heading font-bold text-white mb-3">Éthique</dt>
            <dd class="text-gray-300 text-sm leading-relaxed m-0">
              Je choisis mes projets. Contribuer à un web plus responsable et moins prédateur, c'est
              important pour moi.
            </dd>
          </div>
          <div class="card-glow p-8">
            <dt class="text-xl font-heading font-bold text-white mb-3">Qualité</dt>
            <dd class="text-gray-300 text-sm leading-relaxed m-0">
              Pas de compromis sur le craft. Un travail bâclé, même livré à temps, reste un travail
              bâclé.
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <!-- Section 2: Mes Centres d'Intérêt -->
  <section class="section-padding section-lazy" id="interets" aria-labelledby="interets-heading">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto" data-gsap="reveal">
        <div class="content-section-header">
          <div class="icon-box">
            <svg
              class="w-6 h-6 text-accent-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
              ></path>
            </svg>
          </div>
          <h2 id="interets-heading" class="content-section-title">
            Mes Centres <span class="text-accent-400 underline-memphis underline-memphis-accent"
              >d'Intérêt</span
            >
          </h2>
        </div>
        <div class="section-divider section-divider-accent mb-10"></div>

        <p class="text-gray-400 mb-10 leading-relaxed">
          En dehors du code, j'ai mille centres d'intérêt — tech, créativité, cultures alternatives.
          Voici ce qui me fait vibrer.
        </p>

        <div class="grid md:grid-cols-2 gap-4 sm:gap-6 md:gap-8">
          <div class="card-glow p-4 sm:p-6 md:p-8 flex gap-4 sm:gap-6">
            <div class="icon-box flex-shrink-0">
              <svg
                class="w-6 h-6 text-primary-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-heading font-bold text-white mb-3">Cultures Alternatives</h3>
              <p class="text-gray-300 text-sm leading-relaxed">
                Punk dans l'âme, je m'inspire des mouvements qui remettent en question les normes
                établies. Pop culture et contre-culture nourrissent ma créativité.
              </p>
            </div>
          </div>

          <div class="card-glow p-4 sm:p-6 md:p-8 flex gap-4 sm:gap-6">
            <div class="icon-box flex-shrink-0">
              <svg
                class="w-6 h-6 text-primary-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-heading font-bold text-white mb-3">Curiosité Créative</h3>
              <p class="text-gray-300 text-sm leading-relaxed">
                Passionné par la tech mais aussi par tout ce qui touche à la création — arts
                visuels, musique, culture geek. Je me passionne de tout.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section-padding section-cta relative overflow-hidden section-lazy">
    <div class="container-custom text-center" data-gsap="cta">
      <h2 class="section-title text-white mb-8">
        Envie d'en savoir <span class="text-accent-400 squiggle squiggle-accent">plus</span> ?
      </h2>
      <p class="text-gray-300 text-xl mb-12 max-w-2xl mx-auto leading-relaxed">
        Allez voir mes compétences et mes projets pour vous faire une idée plus concrète.
      </p>
      <div class="flex flex-wrap justify-center gap-4 sm:gap-6 md:gap-8">
        <a
          href={url('/skills')}
          class="btn-chunky bg-white text-dark-900 border-dark-900 hover:bg-gray-100"
          >Mes compétences</a
        >
        <a
          href={url('/projects')}
          class="btn-chunky bg-transparent text-white border-white hover:bg-white hover:text-dark-900"
          >Mes projets</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
