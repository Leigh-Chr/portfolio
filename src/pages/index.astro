---
import DefaultLayout from "../layouts/default-layout.astro";
---

<DefaultLayout>
  <section class="hero">
    <div class="hero-content">
      <div class="tagline">« Code libre, esprit libre »</div>
      <div class="value-proposition">
        <p>
          Développeur‑concepteur engagé, j'accompagne les collectifs et
          associations vers un web libre : expériences accessibles,
          éco‑responsables et transparentes, fusion d'esprit punk et de
          fiabilité.
        </p>
      </div>
      <div class="cta-buttons">
        <a href="/projets" class="btn btn-primary">Voir mes projets</a>
        <a href="/competences" class="btn btn-secondary"
          >Découvrir mes compétences</a
        >
      </div>
    </div>
  </section>

  <footer class="home-footer">
    <div class="contact-info">
      <p>
        <a href="mailto:virgil.chareyre@example.com"
          >virgil.chareyre@example.com</a
        >
      </p>
      <div class="social-links">
        <a
          href="https://linkedin.com/in/virgil-chareyre"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
            ></path><rect x="2" y="9" width="4" height="12"></rect><circle
              cx="4"
              cy="4"
              r="2"></circle></svg
          >
        </a>
        <a
          href="https://github.com/virgil-chareyre"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
            ></path></svg
          >
        </a>
        <a
          href="https://mastodon.social/@virgil_chareyre"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Mastodon"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M21.58 13.913c-.29 1.469-2.608 3.121-5.255 3.439-1.384.151-2.746.287-4.209.225-2.38-.102-4.259-.59-4.259-.59 0 .241.016.471.046.691.331 2.509 2.488 2.657 4.532 2.726 2.064.07 3.904-.499 3.904-.499l.084 1.867s-1.444.772-4.021.924c-1.419.083-3.179-.036-5.226-.71-4.458-1.434-5.211-7.804-5.33-14.14-.035-1.816-.008-3.53-.008-4.969 0-6.242 4.088-8.073 4.088-8.073 2.065-.998 5.602-1.418 9.286-1.452h.09c3.683.034 7.224.454 9.29 1.452 0 0 4.088 1.831 4.088 8.073 0 0 .052 4.604-.101 7.786"
            ></path><path
              d="M18.29 7.784v5.468m-4.533-5.468v5.468m-4.535-5.468v5.468"
            ></path></svg
          >
        </a>
      </div>
    </div>
  </footer>
</DefaultLayout>

<style>
  /* Styles spécifiques à la page d'accueil */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: calc(100vh - 200px);
    padding: var(--spacing-2xl) var(--spacing-md);
  }

  .hero-content {
    max-width: var(--content-width);
  }

  .tagline {
    font-size: 1.8rem;
    font-style: italic;
    color: var(--color-primary);
    margin-bottom: var(--spacing-xl);
  }

  .value-proposition {
    font-size: 1.5rem;
    line-height: 1.4;
    margin-bottom: var(--spacing-2xl);
  }

  .value-proposition p {
    font-weight: 500;
  }

  .cta-buttons {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
    margin-bottom: var(--spacing-2xl);
  }

  .home-footer {
    text-align: center;
    padding: var(--spacing-lg) 0;
    border-top: 1px solid var(--color-border);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
  }

  .social-links {
    display: flex;
    gap: var(--spacing-md);
  }

  .social-links a {
    color: var(--color-text-light);
    transition: color var(--transition-fast);
  }

  .social-links a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--spacing-xl) var(--spacing-md);
    }

    .value-proposition {
      font-size: 1.2rem;
    }

    .cta-buttons {
      flex-direction: column;
      width: 100%;
      max-width: 300px;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
