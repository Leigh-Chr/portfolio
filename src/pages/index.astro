---
import DefaultLayout from "../layouts/default-layout.astro";
import contactsData from "../data/contacts.json";
import { icons } from "../data/icons";

const baseUrl = import.meta.env.BASE_URL;

type SocialItem = {
  username?: string;
  label: string;
  url: string;
  icon: keyof typeof icons;
};

const { email, linkedin, github } = contactsData;

const socialLinks = [linkedin, github] as SocialItem[];
---

<DefaultLayout title="Accueil – Virgil CHAREYRE">
  <section class="hero">
    <div class="hero-content">
      <div class="tagline">
        <span class="typing-text">« Code libre, esprit libre »</span>
        <span class="cursor">|</span>
      </div>
      <div class="value-proposition">
        <p>
          Développeur‑concepteur engagé, mon souhait est d'accompagner vers un
          web plus libre : expériences accessibles, éco‑responsables et
          transparentes.
        </p>
      </div>
      <div class="cta-buttons">
        <a href={`${baseUrl}projets`} class="btn btn-primary">Voir mes projets</a>
        <a href={`${baseUrl}competences`} class="btn btn-secondary"
          >Découvrir mes compétences</a
        >
      </div>
    </div>
  </section>

  <footer class="home-footer">
    <div class="contact-info">
      <p>
        <a href={email.url}>{email.address}</a>
      </p>
      <div class="social-links">
        {
          socialLinks.map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
            >
              <Fragment set:html={icons[social.icon]} />
            </a>
          ))
        }
      </div>
    </div>
  </footer>
</DefaultLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: calc(100vh - 200px);
    padding: var(--spacing-2xl) var(--spacing-md);
  }

  .hero-content {
    max-width: var(--content-width);
  }

  .tagline {
    font-size: 1.8rem;
    font-style: italic;
    color: var(--color-primary);
    margin-bottom: var(--spacing-xl);
  }

  .typing-text {
    overflow: hidden;
    white-space: nowrap;
    animation: typing 3s steps(25, end) 0.5s both;
    display: inline-block;
  }

  .cursor {
    animation: blink 1s infinite;
    margin-left: 2px;
    color: var(--color-coral);
    font-weight: 300;
  }

  @keyframes typing {
    from {
      width: 0;
    }
    to {
      width: 100%;
    }
  }

  @keyframes blink {
    0%,
    50% {
      opacity: 1;
    }
    51%,
    100% {
      opacity: 0;
    }
  }

  .value-proposition {
    font-size: 1.5rem;
    line-height: 1.4;
    margin-bottom: var(--spacing-2xl);
  }

  .value-proposition p {
    font-weight: 500;
  }

  .cta-buttons {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
    margin-bottom: var(--spacing-2xl);
  }

  .home-footer {
    text-align: center;
    padding: var(--spacing-lg) 0;
    border-top: 1px solid var(--color-border);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
  }

  @media (max-width: 768px) {
    .hero {
      padding: var(--spacing-xl) var(--spacing-md);
    }

    .value-proposition {
      font-size: 1.2rem;
    }

    .cta-buttons {
      flex-direction: column;
      width: 100%;
      max-width: 300px;
      margin-left: auto;
      margin-right: auto;
    }
  }
</style>
