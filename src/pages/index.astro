---
import { Image } from 'astro:assets';
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { url } from '@utils/url';
import { getProjectImage } from '@utils/images';
import profileImage from '@assets/images/profile.jpg';
import SkillChart from '@components/SkillChart.astro';

const allSkills = await getCollection('skills');
const allProjects = await getCollection('projects');

const sortedSkills = allSkills.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const chartData = sortedSkills.map((skill) => ({
  name: skill.data.title,
  slug: skill.id,
  level: skill.data.level,
  category: skill.data.category,
  group: skill.data.group,
}));

const featuredProjects = allProjects
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 5);

const skillCount = allSkills.length;
const projectCount = allProjects.length;
const yearsExp = new Date().getFullYear() - 2022;

const jsTs = sortedSkills.find((s) => s.id === 'javascript-typescript');
const problemSolving = sortedSkills.find((s) => s.id === 'problem-solving');
const teamwork = sortedSkills.find((s) => s.id === 'teamwork');
const otherSkills = sortedSkills.filter(
  (s) => s.id !== 'javascript-typescript' && s.id !== 'problem-solving' && s.id !== 'teamwork'
);

function getSkillBarGradient(group: string): string {
  switch (group) {
    case 'frontend':
      return 'linear-gradient(90deg, rgb(34 211 238 / 50%), #22d3ee)';
    case 'backend':
      return 'linear-gradient(90deg, #7c3aed, #a855f7)';
    case 'personal':
      return 'linear-gradient(90deg, rgb(224 255 0 / 60%), #e0ff00)';
    case 'interpersonal':
      return 'linear-gradient(90deg, rgb(251 113 133 / 50%), #fb7185)';
    default:
      return 'linear-gradient(90deg, #7c3aed, #a855f7)';
  }
}

function getSkillIconColor(group: string): string {
  switch (group) {
    case 'frontend':
      return '#22d3ee';
    case 'backend':
      return '#a855f7';
    case 'personal':
      return '#e0ff00';
    case 'interpersonal':
      return '#fb7185';
    default:
      return '#a855f7';
  }
}
---

<BaseLayout title="Accueil">
  <!-- ===================== HERO ===================== -->
  <section class="min-h-screen flex items-center relative overflow-hidden py-20 md:py-32">
    <!-- Background: radial gradients -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div
        class="absolute inset-0"
        style="background: radial-gradient(ellipse 60% 50% at 70% 40%, rgb(124 58 237 / 12%), transparent), radial-gradient(ellipse 40% 40% at 20% 80%, rgb(224 255 0 / 6%), transparent);"
      >
      </div>
    </div>
    <!-- Background: grid lines -->
    <div
      class="absolute inset-0 pointer-events-none opacity-[0.04]"
      aria-hidden="true"
      style="background-image: linear-gradient(var(--color-border-medium) 1px, transparent 1px), linear-gradient(90deg, var(--color-border-medium) 1px, transparent 1px); background-size: 60px 60px; mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, #000 30%, transparent 70%);"
    >
    </div>

    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-[1.3fr_1fr] gap-8 lg:gap-16 items-center">
        <!-- Left: Text content -->
        <div data-gsap="hero">
          <p
            class="flex items-center gap-3 text-xs uppercase tracking-[0.2em] font-heading font-semibold mb-6"
            style="color: var(--color-neon);"
          >
            <span
              class="inline-block w-8 h-[2px] rounded-full"
              style="background: var(--color-neon);"
              aria-hidden="true"></span>
            Portfolio &mdash; Développeur Web Fullstack
          </p>
          <h1
            class="text-4xl sm:text-5xl md:text-6xl lg:text-[4.5rem] font-heading font-bold text-white mb-6 tracking-tight leading-[1.08]"
          >
            Salut, je suis<br />
            <span class="gradient-text-animated">Virgil Chareyre</span>
          </h1>
          <p
            class="text-xl sm:text-2xl lg:text-3xl font-heading font-semibold mb-4"
            style="color: var(--color-text-3);"
          >
            Développeur Web Fullstack
          </p>
          <p
            class="text-base sm:text-lg max-w-xl leading-relaxed mb-8"
            style="color: var(--color-text-4);"
          >
            Le craft et le souci du d&eacute;tail, c'est ce qui me drive. Je cr&eacute;e des
            exp&eacute;riences web soign&eacute;es et accessibles &mdash; parce que le web
            m&eacute;rite mieux que du vite-fait.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href={url('/projects')} class="btn-elevated btn-elevated-primary">
              Voir mes r&eacute;alisations
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
            <a href={url('/contact')} class="btn-elevated btn-elevated-ghost"> Me contacter </a>
          </div>
        </div>

        <!-- Right: Profile image with 3D perspective + floating shapes -->
        <div class="hidden lg:flex items-center justify-center relative" data-gsap="reveal">
          <!-- Glow orb behind avatar -->
          <div
            class="absolute w-80 h-80 rounded-full blur-[80px] opacity-30 pointer-events-none"
            style="background: radial-gradient(circle, rgb(168 85 247 / 50%), transparent);"
            aria-hidden="true"
          >
          </div>

          <!-- Profile image -->
          <div
            class="relative z-10 rounded-3xl overflow-hidden"
            style="transform: perspective(800px) rotateY(-5deg) rotateX(2deg); box-shadow: var(--shadow-glow-violet);"
          >
            <Image
              src={profileImage}
              alt="Photo de Virgil Chareyre"
              class="w-72 h-72 object-cover"
              width={288}
              height={288}
              loading="eager"
              fetchpriority="high"
              format="webp"
              quality={85}
            />
          </div>

          <!-- Floating Memphis shapes -->
          <div
            class="hero-shape absolute -top-6 -left-4 w-14 h-14 border-2 rounded-sm opacity-20"
            style="border-color: var(--color-primary-500); animation: heroFloat1 6s ease-in-out infinite;"
            aria-hidden="true"
          >
          </div>
          <div
            class="hero-shape absolute top-8 -right-8 w-10 h-10 rounded-full opacity-20"
            style="background: var(--color-neon); animation: heroFloat2 8s ease-in-out infinite;"
            aria-hidden="true"
          >
          </div>
          <div
            class="hero-shape absolute -bottom-4 right-12 w-8 h-8 opacity-20"
            style="background: var(--color-primary-500); transform: rotate(45deg); animation: heroFloat3 7s ease-in-out infinite;"
            aria-hidden="true"
          >
          </div>
          <div
            class="hero-shape absolute bottom-16 -left-10 opacity-15 pointer-events-none"
            aria-hidden="true"
            style="animation: heroFloat2 9s ease-in-out infinite;"
          >
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true">
              {
                [0, 1, 2].map((row) =>
                  [0, 1, 2].map((col) => (
                    <circle cx={8 + col * 12} cy={8 + row * 12} r="2" fill="var(--color-text-4)" />
                  ))
                )
              }
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div
      class="absolute bottom-12 left-1/2 -translate-x-1/2 hidden sm:flex items-center gap-8 px-8 py-4 rounded-2xl"
      style="background: rgb(255 255 255 / 4%); backdrop-filter: blur(16px); border: 1px solid var(--color-border-subtle);"
      data-gsap="stats-bar"
    >
      <div class="text-center">
        <p class="text-2xl font-heading font-bold text-white">{skillCount}</p>
        <p class="text-xs uppercase tracking-wider" style="color: var(--color-text-4);">
          Comp&eacute;tences
        </p>
      </div>
      <div class="w-px h-8" style="background: var(--color-border-subtle);" aria-hidden="true">
      </div>
      <div class="text-center">
        <p class="text-2xl font-heading font-bold" style="color: var(--color-neon);">
          {projectCount}
        </p>
        <p class="text-xs uppercase tracking-wider" style="color: var(--color-text-4);">
          R&eacute;alisations
        </p>
      </div>
      <div class="w-px h-8" style="background: var(--color-border-subtle);" aria-hidden="true">
      </div>
      <div class="text-center">
        <p class="text-2xl font-heading font-bold text-white">{yearsExp}</p>
        <p class="text-xs uppercase tracking-wider" style="color: var(--color-text-4);">
          Ann&eacute;es d'exp.
        </p>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div
      class="absolute bottom-4 left-1/2 -translate-x-1/2 hidden lg:flex flex-col items-center gap-2 opacity-40"
      aria-hidden="true"
    >
      <div
        class="w-px h-8 rounded-full"
        style="background: var(--color-text-4); animation: scrollPulse 2s ease-in-out infinite;"
      >
      </div>
    </div>
  </section>

  <!-- ===================== SKILLS BENTO GRID ===================== -->
  <section
    class="py-20 md:py-32 relative overflow-hidden section-lazy"
    aria-labelledby="skills-heading"
    style="background: radial-gradient(ellipse 60% 40% at 50% 0%, rgb(124 58 237 / 6%), transparent);"
  >
    <div class="container-custom">
      <!-- Section header -->
      <div class="text-center mb-16" data-gsap="reveal">
        <p
          class="text-xs uppercase tracking-[0.2em] font-heading font-semibold mb-4"
          style="color: var(--color-primary-400);"
        >
          Comp&eacute;tences
        </p>
        <h2
          id="skills-heading"
          class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-white mb-4 tracking-tight"
        >
          Mon stack <span style="color: var(--color-neon);">technique</span>
        </h2>
        <p
          class="max-w-2xl mx-auto text-base sm:text-lg leading-relaxed"
          style="color: var(--color-text-3);"
        >
          Du technique et de l'humain, parce que l'un ne va pas sans l'autre.
        </p>
      </div>

      <!-- Bento grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4" data-gsap="stagger">
        {/* JS/TS featured card (span 2) */}
        {
          jsTs && (
            <a
              href={url(`/skills/${jsTs.id}`)}
              class="card-glass card-glass-featured sm:col-span-2 lg:col-span-2 p-6 group relative overflow-hidden"
            >
              <div class="flex items-start gap-4 mb-4">
                <div
                  class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 text-xl"
                  style={`background: ${getSkillIconColor(jsTs.data.group)}20; border: 1px solid ${getSkillIconColor(jsTs.data.group)}40;`}
                  transition:name={`skill-icon-${jsTs.id}`}
                >
                  {jsTs.data.icon || '\u2726'}
                </div>
                <div class="flex-1 min-w-0">
                  <h3
                    class="text-lg font-heading font-bold text-white group-hover:text-primary-400 transition-colors"
                    transition:name={`skill-title-${jsTs.id}`}
                  >
                    {jsTs.data.title}
                  </h3>
                  <p class="text-sm mt-1 line-clamp-2" style="color: var(--color-text-4);">
                    {jsTs.data.summary}
                  </p>
                </div>
              </div>
              <div class="skill-bar-elevated">
                <div
                  class="skill-bar-fill-elevated"
                  style={`width: ${jsTs.data.level * 10}%; background: ${getSkillBarGradient(jsTs.data.group)};`}
                />
              </div>
            </a>
          )
        }

        {/* Radar chart card (span 1, row-span 2) */}
        <div
          class="card-glass sm:col-span-2 lg:col-span-1 lg:row-span-2 p-4 flex items-center justify-center overflow-hidden"
        >
          <SkillChart skills={chartData} />
        </div>

        {/* Individual skill cards */}
        {
          otherSkills.map((skill) => (
            <a href={url(`/skills/${skill.id}`)} class="card-glass p-5 group">
              <div
                class="w-10 h-10 rounded-xl flex items-center justify-center mb-3 text-lg"
                style={`background: ${getSkillIconColor(skill.data.group)}20; border: 1px solid ${getSkillIconColor(skill.data.group)}40;`}
                transition:name={`skill-icon-${skill.id}`}
              >
                {skill.data.icon || '\u2726'}
              </div>
              <h3
                class="text-sm font-heading font-bold text-white mb-1 group-hover:text-primary-400 transition-colors"
                transition:name={`skill-title-${skill.id}`}
              >
                {skill.data.title}
              </h3>
              <p class="text-xs line-clamp-2 mb-3" style="color: var(--color-text-4);">
                {skill.data.summary}
              </p>
              <div class="skill-bar-elevated">
                <div
                  class="skill-bar-fill-elevated"
                  style={`width: ${skill.data.level * 10}%; background: ${getSkillBarGradient(skill.data.group)};`}
                />
              </div>
            </a>
          ))
        }

        {/* Problem-solving + Teamwork combined card (span 2) */}
        {
          problemSolving && teamwork && (
            <div class="card-glass sm:col-span-2 lg:col-span-2 p-6 grid grid-cols-1 sm:grid-cols-2 gap-6">
              <a href={url(`/skills/${problemSolving.id}`)} class="group">
                <div class="flex items-start gap-3 mb-3">
                  <div
                    class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 text-lg"
                    style={`background: ${getSkillIconColor(problemSolving.data.group)}20; border: 1px solid ${getSkillIconColor(problemSolving.data.group)}40;`}
                    transition:name={`skill-icon-${problemSolving.id}`}
                  >
                    {problemSolving.data.icon || '\u2726'}
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3
                      class="text-sm font-heading font-bold text-white group-hover:text-primary-400 transition-colors"
                      transition:name={`skill-title-${problemSolving.id}`}
                    >
                      {problemSolving.data.title}
                    </h3>
                    <p class="text-xs line-clamp-2 mt-1" style="color: var(--color-text-4);">
                      {problemSolving.data.summary}
                    </p>
                  </div>
                </div>
                <div class="skill-bar-elevated">
                  <div
                    class="skill-bar-fill-elevated"
                    style={`width: ${problemSolving.data.level * 10}%; background: ${getSkillBarGradient(problemSolving.data.group)};`}
                  />
                </div>
              </a>
              <a href={url(`/skills/${teamwork.id}`)} class="group">
                <div class="flex items-start gap-3 mb-3">
                  <div
                    class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 text-lg"
                    style={`background: ${getSkillIconColor(teamwork.data.group)}20; border: 1px solid ${getSkillIconColor(teamwork.data.group)}40;`}
                    transition:name={`skill-icon-${teamwork.id}`}
                  >
                    {teamwork.data.icon || '\u2726'}
                  </div>
                  <div class="flex-1 min-w-0">
                    <h3
                      class="text-sm font-heading font-bold text-white group-hover:text-primary-400 transition-colors"
                      transition:name={`skill-title-${teamwork.id}`}
                    >
                      {teamwork.data.title}
                    </h3>
                    <p class="text-xs line-clamp-2 mt-1" style="color: var(--color-text-4);">
                      {teamwork.data.summary}
                    </p>
                  </div>
                </div>
                <div class="skill-bar-elevated">
                  <div
                    class="skill-bar-fill-elevated"
                    style={`width: ${teamwork.data.level * 10}%; background: ${getSkillBarGradient(teamwork.data.group)};`}
                  />
                </div>
              </a>
            </div>
          )
        }
      </div>

      <!-- Link to all skills -->
      <div class="text-center mt-12">
        <a href={url('/skills')} class="btn-elevated btn-elevated-ghost">
          Voir toutes mes comp&eacute;tences
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== PROJECTS CINEMATIC ===================== -->
  <section
    class="py-20 md:py-32 relative overflow-hidden section-lazy"
    aria-labelledby="projects-heading"
  >
    <div class="container-custom">
      <!-- Section header -->
      <div class="text-center mb-16" data-gsap="reveal">
        <p
          class="text-xs uppercase tracking-[0.2em] font-heading font-semibold mb-4"
          style="color: var(--color-primary-400);"
        >
          R&eacute;alisations
        </p>
        <h2
          id="projects-heading"
          class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-white mb-4 tracking-tight"
        >
          Projets <span style="color: var(--color-neon);">s&eacute;lectionn&eacute;s</span>
        </h2>
        <p
          class="max-w-2xl mx-auto text-base sm:text-lg leading-relaxed"
          style="color: var(--color-text-3);"
        >
          Ce sur quoi j'ai boss&eacute; ces derni&egrave;res ann&eacute;es, en entreprise et en
          perso.
        </p>
      </div>

      <!-- Project grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-gsap="stagger">
        {
          featuredProjects.map((project, index) => {
            const thumbImage = project.data.thumbnail
              ? getProjectImage(project.data.thumbnail)
              : undefined;
            const isFeatured = index === 0;
            const thumbHeight = isFeatured ? 'h-48 md:h-[280px]' : 'h-44 md:h-[220px]';
            const skillTags = (project.data.relatedSkills ?? []).slice(0, 3);

            return (
              <a
                href={url(`/projects/${project.id}`)}
                class:list={[
                  'card-glass overflow-hidden group relative',
                  { 'md:col-span-2': isFeatured },
                ]}
              >
                {/* Thumbnail area */}
                <div
                  class={`relative overflow-hidden ${thumbHeight}`}
                  style="background: linear-gradient(135deg, rgb(124 58 237 / 15%), rgb(224 255 0 / 5%));"
                  transition:name={`project-thumb-${project.id}`}
                >
                  {/* Checkerboard pattern */}
                  <div
                    class="absolute inset-0 opacity-[0.05] pointer-events-none"
                    style="background-image: repeating-conic-gradient(var(--color-text-4) 0% 25%, transparent 0% 50%); background-size: 20px 20px;"
                    aria-hidden="true"
                  />

                  {thumbImage ? (
                    <Image
                      src={thumbImage}
                      alt={`Aperçu du projet ${project.data.title}`}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                      loading="lazy"
                      decoding="async"
                      width={isFeatured ? 800 : 400}
                      height={isFeatured ? 280 : 220}
                    />
                  ) : (
                    <div class="absolute inset-0 flex items-center justify-center">
                      <span
                        class="text-[4rem] sm:text-[6rem] font-heading font-bold uppercase opacity-[0.06] select-none whitespace-nowrap"
                        style="color: var(--color-text-1);"
                      >
                        {project.data.title}
                      </span>
                    </div>
                  )}

                  {/* Gradient overlay */}
                  <div
                    class="absolute inset-0 bg-gradient-to-t from-dark-900/80 via-transparent to-transparent pointer-events-none"
                    aria-hidden="true"
                  />

                  {/* Arrow icon on hover */}
                  <div
                    class="absolute top-4 right-4 w-10 h-10 rounded-xl flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300"
                    style="background: rgb(168 85 247 / 80%);"
                    aria-hidden="true"
                  >
                    <svg
                      class="w-5 h-5 text-white"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M7 17L17 7M17 7H7M17 7v10"
                      />
                    </svg>
                  </div>
                </div>

                {/* Info */}
                <div class="p-5 sm:p-6">
                  {skillTags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-3">
                      {skillTags.map((tag: string) => (
                        <span
                          class="text-[10px] uppercase tracking-wider font-heading font-semibold px-2 py-0.5 rounded-full"
                          style="color: var(--color-primary-300); background: rgb(168 85 247 / 10%); border: 1px solid rgb(168 85 247 / 20%);"
                        >
                          {tag.replace(/-/g, ' ')}
                        </span>
                      ))}
                    </div>
                  )}
                  <h3
                    class="text-lg sm:text-xl font-heading font-bold text-white mb-2 group-hover:text-primary-400 transition-colors"
                    transition:name={`project-title-${project.id}`}
                  >
                    {project.data.title}
                  </h3>
                  <p class="text-sm line-clamp-2" style="color: var(--color-text-4);">
                    {project.data.shortDescription}
                  </p>
                </div>
              </a>
            );
          })
        }
      </div>

      <!-- Link to all projects -->
      <div class="text-center mt-12">
        <a href={url('/projects')} class="btn-elevated btn-elevated-ghost">
          Voir toutes mes r&eacute;alisations
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===================== CTA IMMERSIVE ===================== -->
  <section
    class="py-20 md:py-32 relative overflow-hidden section-lazy"
    aria-labelledby="cta-heading"
  >
    <!-- Background gradients -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div
        class="absolute inset-0"
        style="background: radial-gradient(ellipse 50% 50% at 50% 50%, rgb(124 58 237 / 10%), transparent), radial-gradient(ellipse 30% 40% at 70% 60%, rgb(224 255 0 / 5%), transparent);"
      >
      </div>
    </div>

    <!-- Top border gradient -->
    <div
      class="absolute top-0 left-0 right-0 h-px"
      style="background: linear-gradient(90deg, transparent, var(--color-primary-500), var(--color-neon), var(--color-primary-500), transparent);"
      aria-hidden="true"
    >
    </div>

    <!-- Floating decorative shapes -->
    <div
      class="absolute top-20 left-[10%] w-16 h-16 rounded-full opacity-[0.06] pointer-events-none hidden sm:block"
      style="border: 2px solid var(--color-primary-500); animation: heroFloat1 8s ease-in-out infinite;"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute bottom-20 right-[15%] w-10 h-10 opacity-[0.06] pointer-events-none hidden sm:block"
