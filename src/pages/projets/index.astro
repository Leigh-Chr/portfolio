---
import DefaultLayout from "../../layouts/default-layout.astro";

// Définition des projets
const projets = [
  {
    slug: "portail-associatif",
    title: "Refonte portail associatif",
    image: "/images/projects/portail-associatif.jpg",
    tags: ["Accessibilité", "UX/UI", "Refonte"],
    description:
      "Transformation d'un portail vieillissant en plateforme inclusive adaptée à tous les publics associatifs.",
  },
  {
    slug: "gestion-collaborative",
    title: "Application de gestion collaborative",
    image: "/images/projects/gestion-collaborative.jpg",
    tags: ["SaaS", "Angular", "Agile"],
    description:
      "Outil de gestion de tâches et projets pensé pour les équipes distribuées et les structures à gouvernance partagée.",
  },
  {
    slug: "tableau-bord-accessible",
    title: "Tableau de bord analytique accessible",
    image: "/images/projects/tableau-bord.jpg",
    tags: ["Dataviz", "Accessibilité", "Frontend"],
    description:
      "Visualisation de données complexes rendue accessible à tous, y compris aux utilisateurs de technologies d'assistance.",
  },
  {
    slug: "plateforme-documentaire",
    title: "Plateforme documentaire libre",
    image: "/images/projects/plateforme-documentaire.jpg",
    tags: ["Open Source", "Collaboration", "Architecture"],
    description:
      "Système de gestion documentaire éthique favorisant le partage de connaissances entre organisations à but non lucratif.",
  },
  {
    slug: "service-public-numerique",
    title: "Modernisation service public numérique",
    image: "/images/projects/service-public.jpg",
    tags: ["Service public", "Sobriété", "Accessibilité"],
    description:
      "Refonte inclusive et éco-responsable d'un service numérique utilisé par des milliers de citoyens au quotidien.",
  },
];
---

<DefaultLayout>
  <section class="page-section">
    <h1>Projets</h1>

    <div class="intro">
      <p>
        Sélection de projets représentatifs de ma démarche et de mes valeurs,
        chacun illustrant différentes facettes de mon approche du développement
        web.
      </p>
    </div>

    <div class="projects-grid">
      {
        projets.map((projet) => (
          <a href={`/projets/${projet.slug}`} class="project-card">
            <div class="project-image">
              <img
                src={projet.image}
                alt={`Aperçu du projet ${projet.title}`}
                loading="lazy"
              />
            </div>
            <div class="project-content">
              <h2>{projet.title}</h2>
              <div class="tags">
                {projet.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <p class="project-description">{projet.description}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</DefaultLayout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--spacing-xl);
  }

  .project-card {
    display: block;
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow: var(--box-shadow);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    text-decoration: none;
    color: var(--color-text);
    background-color: var(--color-background);
    height: 100%;
  }

  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--box-shadow-hover);
    text-decoration: none;
  }

  .project-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .project-card:hover .project-image img {
    transform: scale(1.05);
  }

  .project-content {
    padding: var(--spacing-md);
  }

  .project-content h2 {
    margin-top: 0;
    margin-bottom: var(--spacing-sm);
    font-size: 1.25rem;
    color: var(--color-primary);
    border-bottom: none;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: calc(var(--spacing-xs) / 2);
    margin-bottom: var(--spacing-sm);
  }

  .tag {
    font-size: 0.8rem;
    padding: calc(var(--spacing-xs) / 2) var(--spacing-xs);
    background-color: var(--color-background-alt);
    color: var(--color-secondary);
    border-radius: 4px;
    display: inline-block;
  }

  .project-description {
    font-size: 0.95rem;
    margin-bottom: 0;
    color: var(--color-text);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
