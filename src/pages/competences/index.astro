---
import DefaultLayout from "../../layouts/default-layout.astro";
import skills from "../../data/skills.json";

const softSkills = skills.filter((skill) => skill.type === "soft");
const technicalSkills = skills.filter((skill) => skill.type === "tech");

interface Skill {
  id: string;
  name: string;
  type: string;
  definition: string;
  proof: string;
  self_review: string;
  evolution: string;
  projects: string[];
}
---

<DefaultLayout>
  <section class="page-section">
    <h1>Compétences</h1>

    <div class="intro">
      <p>
        Mon profil combine compétences relationnelles et techniques pour créer
        des expériences numériques inclusives et efficaces. J'aborde chaque
        projet avec une double vision : celle d'un artisan attentif aux détails
        techniques et celle d'un médiateur qui place l'humain au centre.
      </p>
    </div>

    <div class="skills-grid two-column-grid">
      <div class="skills-category">
        <h2>Soft skills</h2>
        <div class="skills-tags">
          {
            softSkills.map((skill) => (
              <a href={`/competences/${skill.id}`} class="tag">
                {skill.name}
              </a>
            ))
          }
        </div>
      </div>

      <div class="skills-category">
        <h2>Compétences techniques</h2>
        <div class="skills-tags">
          {
            technicalSkills.map((skill) => (
              <a href={`/competences/${skill.id}`} class="tag">
                {skill.name}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>

<style>
  .skills-category h2 {
    margin-top: 0;
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--spacing-lg);
  }

  .skills-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
  }

  .tag {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: var(--border-radius-pill);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    transition: all var(--transition-fast);
    background-color: var(--color-primary);
    color: white;
  }

  .tag:hover {
    background-color: var(--color-primary-dark);
    color: white;
    text-decoration: none;
    transform: translateY(-2px);
  }
</style>
