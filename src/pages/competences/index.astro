---
import DefaultLayout from "../../layouts/default-layout.astro";

// Définition des compétences avec leur niveau d'affinité
const softSkills = [
  { name: "Empathie active", affinity: "forte" },
  { name: "Communication inclusive", affinity: "forte" },
  { name: "Gestion agile centrée utilisateur", affinity: "forte" },
  { name: "Sens critique & éthique", affinity: "forte" },
  { name: "Autonomie responsable", affinity: "modérée" },
];

const technicalSkills = [
  { name: "Conception UX/UI & wireframing", affinity: "forte" },
  {
    name: "Développement front (HTML • CSS • TypeScript / Angular)",
    affinity: "forte",
  },
  { name: "Accessibilité (WCAG 2.x)", affinity: "forte" },
  { name: "Gestion de projet client‑centré", affinity: "modérée" },
  { name: "Tests fonctionnels & itératifs", affinity: "modérée" },
];
---

<DefaultLayout>
  <section class="page-section">
    <h1>Compétences</h1>

    <div class="intro">
      <p>
        Mon profil combine compétences relationnelles et techniques pour créer
        des expériences numériques inclusives et efficaces. J'aborde chaque
        projet avec une double vision : celle d'un artisan attentif aux détails
        techniques et celle d'un médiateur qui place l'humain au centre.
      </p>
    </div>

    <div class="skills-grid two-column-grid">
      <div class="skills-category">
        <h2>Soft skills</h2>
        <div class="skills-tags">
          {
            softSkills.map((skill) => (
              <a
                href={`/competences/${skill.name
                  .toLowerCase()
                  .replace(/\s+/g, "-")
                  .replace(/[^\w-]/g, "")}`}
                class={`tag tag-${skill.affinity}`}
              >
                {skill.name}
              </a>
            ))
          }
        </div>
      </div>

      <div class="skills-category">
        <h2>Compétences techniques</h2>
        <div class="skills-tags">
          {
            technicalSkills.map((skill) => (
              <a
                href={`/competences/${skill.name
                  .toLowerCase()
                  .replace(/\s+/g, "-")
                  .replace(/[^\w-]/g, "")}`}
                class={`tag tag-${skill.affinity}`}
              >
                {skill.name}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <div class="legend">
      <div class="legend-item">
        <span class="tag-sample tag-forte"></span>
        <span>Affinité forte</span>
      </div>
      <div class="legend-item">
        <span class="tag-sample tag-modérée"></span>
        <span>Affinité modérée</span>
      </div>
    </div>
  </section>
</DefaultLayout>

<style>
  .skills-category h2 {
    margin-top: 0;
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--spacing-lg);
  }

  .skills-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
  }

  .tag {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: var(--border-radius-pill);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    transition: all var(--transition-fast);
  }

  .tag-forte {
    background-color: var(--color-primary);
    color: white;
  }

  .tag-forte:hover {
    background-color: var(--color-primary-dark);
    color: white;
    text-decoration: none;
    transform: translateY(-2px);
  }

  .tag-modérée {
    background-color: var(--color-background-alt);
    color: var(--color-secondary);
    border: 1px solid var(--color-border);
  }

  .tag-modérée:hover {
    background-color: var(--color-border);
    text-decoration: none;
    transform: translateY(-2px);
  }

  .legend {
    display: flex;
    justify-content: center;
    gap: var(--spacing-lg);
    margin-top: var(--spacing-xl);
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
  }

  .tag-sample {
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    display: inline-block;
  }

  .tag-sample.tag-forte {
    background-color: var(--color-primary);
  }

  .tag-sample.tag-modérée {
    background-color: var(--color-background-alt);
    border: 1px solid var(--color-border);
  }
</style>
