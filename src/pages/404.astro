---
import BaseLayout from '@layouts/BaseLayout.astro';
import Icon from '@components/Icon.astro';
import { url } from '@utils/url';
---

<BaseLayout
  title="Page non trouvée"
  description="La page que vous recherchez n'existe pas ou a été déplacée."
  robots="noindex, nofollow"
>
  <section class="min-h-[80vh] flex items-center relative overflow-hidden py-20 md:py-32">
    <div class="container-custom text-center">
      <div class="max-w-2xl mx-auto" data-gsap="hero">
        <!-- 404 Number -->
        <div class="mb-10">
          <span
            class="text-[10rem] md:text-[14rem] font-heading font-black leading-none gradient-text-animated"
          >
            404
          </span>
        </div>

        <!-- Message -->
        <h1 class="text-3xl md:text-4xl font-heading font-bold text-white mb-6">
          Oups ! Page <span class="text-primary-400 underline-memphis">introuvable</span>
        </h1>
        <p class="text-gray-400 text-lg mb-12 max-w-md mx-auto leading-relaxed">
          La page que vous recherchez n'existe pas, a été déplacée ou est temporairement
          indisponible.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap justify-center gap-6">
          <a href={url('/')} class="btn-chunky-primary">
            <Icon name="home" />
            Retour à l'accueil
          </a>
          <a href={url('/contact')} class="btn-chunky-accent"> Me contacter </a>
        </div>

        <!-- Quick Links -->
        <nav class="mt-16 pt-10 border-t border-dark-700" aria-label="Pages suggérées">
          <p class="text-gray-500 text-sm mb-6">Ou explorez ces pages :</p>
          <div class="flex flex-wrap justify-center gap-6">
            <a
              href={url('/skills')}
              class="text-primary-400 hover:text-primary-300 font-heading font-medium transition-colors"
            >
              Compétences
            </a>
            <span class="text-dark-600" aria-hidden="true">•</span>
            <a
              href={url('/projects')}
              class="text-primary-400 hover:text-primary-300 font-heading font-medium transition-colors"
            >
              Projets
            </a>
            <span class="text-dark-600" aria-hidden="true">•</span>
            <a
              href={url('/timeline')}
              class="text-primary-400 hover:text-primary-300 font-heading font-medium transition-colors"
            >
              Parcours
            </a>
            <span class="text-dark-600" aria-hidden="true">•</span>
            <a
              href={url('/about')}
              class="text-primary-400 hover:text-primary-300 font-heading font-medium transition-colors"
            >
              À propos
            </a>
          </div>
        </nav>
      </div>
    </div>
  </section>
</BaseLayout>
