const isStroke = name in strokeIcons;
const pathData = strokeIcons[name] ?? fillIcons[name] ?? '';
---

{
  isStroke ? (
    <svg
      class={className}
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
      set:html={pathData}
    />
  ) : (
    <svg
      class={className}
      fill="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
      set:html={pathData}
    />
  )
}
