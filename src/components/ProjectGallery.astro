---
import { Image } from 'astro:assets';
import { getProjectImage, isVideo } from '@utils/images';
import { url } from '@utils/url';

interface Props {
  gallery: { src: string; alt: string }[];
}

const { gallery } = Astro.props;

const items = gallery.map((item) => {
  const video = isVideo(item.src);
  const image = video ? undefined : getProjectImage(item.src);
  const videoSrc = video ? url(item.src) : undefined;
  return { ...item, video, image, videoSrc };
});
---

<section class="gallery-section" data-gsap="reveal">
  <div class="content-section-header">
    <div class="icon-box-sm">
      <span class="text-xl" aria-hidden="true">📸</span>
    </div>
    <h2 class="content-section-title">
      <span class="text-primary-400 underline-memphis">Galerie</span>
    </h2>
  </div>
  <div class="section-divider ml-0 mx-0 mb-8"></div>

  <div class="gallery-grid">
    {
      items.map((item, index) =>
        item.video ? (
          <figure class="gallery-item">
            <video
              autoplay
              loop
              muted
              playsinline
              class="w-full h-full object-cover"
              aria-label={item.alt}
            >
              <source src={item.videoSrc} type="video/mp4" />
            </video>
            <figcaption class="gallery-caption">{item.alt}</figcaption>
          </figure>
        ) : item.image ? (
          <figure class="gallery-item">
            <button
              type="button"
              class="gallery-trigger"
              data-gallery-index={index}
              aria-label={`Agrandir : ${item.alt}`}
            >
              <Image
                src={item.image}
                alt={item.alt}
                class="w-full h-full object-cover"
                width={600}
                loading="lazy"
              />
              <span class="gallery-zoom-icon" aria-hidden="true">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"
                  />
                </svg>
              </span>
            </button>
            <figcaption class="gallery-caption">{item.alt}</figcaption>
          </figure>
        ) : null
      )
    }
  </div>

  {/* Lightbox dialog */}
  <dialog class="gallery-lightbox" aria-label="Image agrandie">
    <div class="gallery-lightbox-content">
      <button type="button" class="gallery-lightbox-close" aria-label="Fermer">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
      <img class="gallery-lightbox-img" src="" alt="" />
    </div>
  </dialog>
</section>

<script>
  function initGallery() {
    const triggers = document.querySelectorAll<HTMLButtonElement>('.gallery-trigger');
    const dialog = document.querySelector<HTMLDialogElement>('.gallery-lightbox');
    const img = dialog?.querySelector<HTMLImageElement>('.gallery-lightbox-img');
    const closeBtn = dialog?.querySelector<HTMLButtonElement>('.gallery-lightbox-close');

    if (!dialog || !img || !closeBtn) return;

    for (const trigger of triggers) {
      const galleryImg = trigger.querySelector('img');
      if (!galleryImg) continue;

      trigger.addEventListener('click', () => {
        img.src = galleryImg.src;
        img.alt = galleryImg.alt;
        dialog.showModal();
      });
    }

    closeBtn.addEventListener('click', () => dialog.close());

    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
  }

  document.addEventListener('astro:page-load', initGallery);
</script>
