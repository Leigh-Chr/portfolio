---
import { Image } from 'astro:assets';
import { mainNavigation } from '@/config/navigation';
import Icon from '@components/Icon.astro';
import profileImage from '@assets/images/profile.jpg';

const currentYear = new Date().getFullYear();
---

<footer class="border-t-2 border-dark-700 relative overflow-hidden">
  <div class="container-custom py-12 md:py-16 relative">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 lg:gap-16">
      <!-- Identity -->
      <div>
        <div class="flex items-center gap-4 mb-6">
          <div class="profile-avatar">
            <div class="w-full h-full bg-dark-700 flex items-center justify-center overflow-hidden">
              <Image
                src={profileImage}
                alt=""
                class="w-full h-full object-cover"
                width={48}
                height={48}
                loading="lazy"
                format="webp"
                quality={80}
              />
            </div>
          </div>
          <div>
            <p class="font-heading font-bold text-lg text-white">Virgil CHAREYRE</p>
            <p class="text-sm text-gray-400">Développeur Web Fullstack</p>
          </div>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed">
          Esprit libre et développeur engagé. Une grande sensibilité et l'envie de créer des choses
          qui comptent vraiment.
        </p>
      </div>

      <!-- Quick Links -->
      <nav aria-label="Navigation du pied de page">
        <h2 class="font-heading font-bold text-lg text-white mb-6 flex items-center gap-3">
          <span class="w-2 h-2 bg-primary-500" aria-hidden="true"></span>
          Navigation
        </h2>
        <ul class="space-y-1">
          {
            mainNavigation.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="block py-2 -my-px text-gray-400 hover:text-primary-400 transition-colors text-sm font-medium min-h-[44px] flex items-center"
                >
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Contact -->
      <section aria-labelledby="footer-contact-heading">
        <h2
          id="footer-contact-heading"
          class="font-heading font-bold text-lg text-white mb-6 flex items-center gap-3"
        >
          <span class="w-2 h-2 bg-accent-400" aria-hidden="true"></span>
          Contact
        </h2>
        <address class="space-y-4 not-italic">
          <a
            href="mailto:virgil.07@hotmail.fr"
            class="flex items-center gap-3 py-2 text-gray-400 hover:text-primary-400 transition-colors text-sm group min-h-[44px]"
          >
            <span
              class="w-8 h-8 flex items-center justify-center bg-dark-800 border border-dark-600 group-hover:border-primary-500 transition-colors"
            >
              <Icon name="email" class="w-4 h-4" />
            </span>
            virgil.07@hotmail.fr
          </a>
          <a
            href="https://linkedin.com/in/virgil-chareyre"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 py-2 text-gray-400 hover:text-primary-400 transition-colors text-sm group min-h-[44px]"
          >
            <span
              class="w-8 h-8 flex items-center justify-center bg-dark-800 border border-dark-600 group-hover:border-primary-500 transition-colors"
            >
              <Icon name="linkedin" class="w-4 h-4" />
            </span>
            LinkedIn<span class="sr-only"> (nouvelle fenêtre)</span>
          </a>
          <a
            href="https://github.com/Leigh-Chr"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 py-2 text-gray-400 hover:text-primary-400 transition-colors text-sm group min-h-[44px]"
          >
            <span
              class="w-8 h-8 flex items-center justify-center bg-dark-800 border border-dark-600 group-hover:border-primary-500 transition-colors"
            >
              <Icon name="github" class="w-4 h-4" />
            </span>
            GitHub<span class="sr-only"> (nouvelle fenêtre)</span>
          </a>
        </address>
      </section>
    </div>

    <!-- Bottom Bar -->
    <div
      class="mt-16 pt-10 border-t border-dark-700 flex flex-col md:flex-row justify-between items-center gap-6"
    >
      <p class="text-gray-400 text-sm">
        &copy; {currentYear}
        <span class="text-primary-400">Virgil CHAREYRE</span>
      </p>
      <p class="text-gray-400 text-sm flex items-center gap-2">
        <span class="w-2 h-2 bg-accent-400" aria-hidden="true"></span>
        Fait main à Grenoble
      </p>
    </div>
  </div>
</footer>
